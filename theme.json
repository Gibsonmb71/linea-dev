{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1180px"
    },
    "color": {
      "palette": [
        {
          "name": "Ink",
          "slug": "ink",
          "color": "#141414"
        },
        {
          "name": "Paper",
          "slug": "paper",
          "color": "#fffdf8"
        },
        {
          "name": "Muted",
          "slug": "muted",
          "color": "#666666"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#7a1f2b"
        },
        {
          "name": "Accent Dark",
          "slug": "accent-dark",
          "color": "#4d101a"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "Georgia, 'Times New Roman', serif",
          "name": "Serif",
          "slug": "serif"
        },
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
          "name": "System Sans",
          "slug": "system-sans"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Normal",
          "slug": "normal",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.5rem"
        },
        {
          "name": "Extra Large",
          "slug": "x-large",
          "size": "clamp(2rem, 5vw, 4rem)"
        }
      ]
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "em",
        "%",
        "vw",
        "vh"
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|paper",
      "text": "var:preset|color|ink"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|system-sans",
      "fontSize": "var:preset|font-size|normal",
      "lineHeight": "1.65"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var:preset|color|accent",
          "text": "var:preset|color|paper"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1rem",
            "bottom": "0.75rem",
            "left": "1rem"
          }
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|serif",
          "lineHeight": "1.1"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|accent"
        }
      }
    },
    "blocks": {
      "core/post-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|serif"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "700",
          "textTransform": "uppercase"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
